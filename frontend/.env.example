# -------------------------------------------------------------
# FRONTEND ENVIRONMENT VARIABLES
# -------------------------------------------------------------

# LOCAL DEVELOPMENT:
# Leave VITE_API_URL empty. The app will use '/api' and Vite will 
# proxy requests to localhost:3001 automatically.
VITE_API_URL=

# PRODUCTION (VERCEL):
# Add this variable in your Vercel Dashboard (Settings > Environment Variables)
# Set it to your deployed Render backend URL WITH the /api suffix.
# Example: 
# VITE_API_URL=https://sentinelops-backend-kvzr.onrender.com/api
